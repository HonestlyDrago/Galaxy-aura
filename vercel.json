{
  "version": 2,
  "buildCommand": "pnpm build && node_modules/.bin/esbuild server/vercel-entry.ts --platform=node --packages=external --bundle --format=esm --alias:@shared=./shared --outfile=api/bundle.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/bundle.mjs" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
